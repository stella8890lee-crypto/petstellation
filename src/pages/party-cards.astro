---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead 
      title="Catalog | Petstellation"
      description="Browse all Petstellation digital pet products."
    />
  </head>

  <body>
    <Header />

    <main class="catalog-page">

      <div class="catalog-container">

        <!-- TITLE -->
        <h1 class="catalog-title">CATALOG</h1>

        <!-- CATEGORY ROW -->
        <div class="category-row">
          <a href="#">Bundle Products</a>
          <a href="#">Party Cards</a>
          <a href="#">Gift Tags</a>
          <a href="#">Memory Keepsake DIY</a>
          <a href="#">Training Programs</a>
          <a href="#">Pet Planners</a>
          <a href="#">Pet Checklists</a>
        </div>

        <!-- PRODUCT GRID -->
        <div class="product-grid">

          <!-- PRODUCT CARD 1 -->
           <a href="https://petstellation.lemonsqueezy.com/buy/18ff54a6-2baa-4675-acca-6348532ec9cb">
        <img src="/20A.png" alt="Vet Check-Up Card In 10 Languages – Multilingual Pet Birthday & Wellness Gift" width="410" height="410" />
        <h4>Vet Check-Up Card In 10 Languages – Multilingual Pet Birthday & Wellness Gift(20A)</h4>
        <p class="price">$8.99 USD | Instant Download</p>
      </a>

          <!-- PRODUCT CARD 2 -->
          <!-- 复制上面整个 a.product-card 改链接即可 -->

          <!-- PRODUCT CARD 3 -->

          <!-- PRODUCT CARD 4 -->

        </div>

      </div>

    </main>

    <Footer />

    <!-- STYLES -->
    <style>
      /* ===== 页面整体宽度（关键） ===== */
      .catalog-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 50px 24px;
      }

      /* ===== 标题 ===== */
      .catalog-title {
        font-size: 42px;
        text-align: center;
        margin-bottom: 30px;
        letter-spacing: 2px;
        font-weight: 600;
      }

      /* ===== 分类导航（保持一行） ===== */
      .category-row {
        display: flex;
        flex-wrap: nowrap;
        overflow-x: auto;
        gap: 20px;
        margin-bottom: 45px;
        white-space: nowrap;
        justify-content: center;
      }

      .category-row a {
        font-size: 14px;
        color: #444;
        text-decoration: none;
      }

      .category-row a:hover {
        color: #000;
      }

      /* ===== 产品网格（对齐首页） ===== */
      .product-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 28px;
      }

      /* ===== 产品卡片 ===== */
      .product-card {
        text-decoration: none;
        color: inherit;
        display: block;
      }

      /* 图片（重点修复你说的太小问题） */
      .product-card img {
        width: 100%;
        height: auto;
        border-radius: 12px;
        display: block;
      }

      /* 标题（不要太大） */
      .product-card h4 {
        font-size: 15px;
        margin: 12px 0 6px;
        font-weight: 500;
        line-height: 1.4;
      }

      /* 价格（更轻） */
      .product-card .price {
        font-size: 14px;
        color: #666;
      }

      /* hover效果（提升质感） */
      .product-card:hover {
        transform: translateY(-2px);
        transition: 0.2s ease;
      }

      /* ===== 移动端适配 ===== */
      @media (max-width: 900px) {
        .product-grid {
          grid-template-columns: repeat(2, 1fr);
        }
      }

      @media (max-width: 600px) {
        .product-grid {
          grid-template-columns: 1fr;
        }

        .catalog-title {
          font-size: 32px;
        }
      }
    </style>

  </body>
</html>
